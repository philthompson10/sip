#ifndef _SIP_H
#define _SIP_H


#include <Python.h>

#include <limits.h>
#include <stdbool.h>
#include <stdint.h>


/* Sanity check on the Python version. */
#if PY_VERSION_HEX < 0x030f0000
#error "This version of @_SIP_MODULE_FQ_NAME@ requires Python v3.15 or later"
#endif


/* Specify the module configuration. */
#define SIP_CONFIGURATION @_SIP_CONFIGURATION@
@_SIP_PyEnums_STATE@ SIP_CONFIGURATION_PyEnums
@_SIP_CustomEnums_STATE@ SIP_CONFIGURATION_CustomEnums


#ifdef __cplusplus
#include <exception>

typedef bool (*sipExceptionHandler)(std::exception_ptr);
#else
typedef void *sipExceptionHandler;
#endif


#ifdef __cplusplus
extern "C" {
#endif


/* The version of the ABI. */
#define SIP_ABI_MAJOR_VERSION       14
#define SIP_ABI_MINOR_VERSION       0
#define SIP_MODULE_PATCH_VERSION    0


/*
 * The change history of the ABI.
 *
 * v14.0
 *  - The initial v14 version.
 */


/* The version of the code generator. */
#define SIP_VERSION                 @_SIP_VERSION@
#define SIP_VERSION_STR             "@_SIP_VERSION_STR@"

/* These are all dependent on the user-specified name of the sip module. */
#define _SIP_MODULE_FQ_NAME         "@_SIP_MODULE_FQ_NAME@"
#define _SIP_MODULE_NAME            "@_SIP_MODULE_NAME@"
#define _SIP_MODULE_SHARED          @_SIP_MODULE_SHARED@
#define _SIP_MODULE_ENTRY           @_SIP_MODULE_ENTRY@
#define _SIP_MODULE_SLOTS           @_SIP_MODULE_SLOTS@


/*
 * Qt includes this typedef and its meta-object system explicitly converts
 * types to uint.  If these correspond to signal arguments then that conversion
 * is exposed.  Therefore SIP generates code that uses it.  This definition is
 * for the cases that SIP is generating non-Qt related bindings with compilers
 * that don't include it themselves (i.e. MSVC).
 */
// TODO Remove if possible.
typedef unsigned int uint;


/* Some C++ compatibility stuff. */
#if defined(__cplusplus)

/*
 * Cast to a PyCFunction in such a way that it suppresses the GCC
 * -Wcast-function-type warning.
 */
#define SIP_MLMETH_CAST(m)  reinterpret_cast<PyCFunction>(reinterpret_cast<void (*)(void)>(m))

#if __cplusplus >= 201103L || defined(_MSVC_LANG)

/* C++11 and later. */
#define SIP_NULLPTR     nullptr
#define SIP_OVERRIDE    override

#else

/* Earlier versions of C++. */
#define SIP_NULLPTR     NULL
#define SIP_OVERRIDE

#endif

#else

/* Cast to a PyCFunction. */
#define SIP_MLMETH_CAST(m)  ((PyCFunction)(m))

/* C. */
#define SIP_NULLPTR     NULL
#define SIP_OVERRIDE

#endif


/*
 * The mask that can be passed to sipTrace().
 */
#define SIP_TRACE_CATCHERS  0x0001
#define SIP_TRACE_CTORS     0x0002
#define SIP_TRACE_DTORS     0x0004
#define SIP_TRACE_INITS     0x0008
#define SIP_TRACE_DEALLOCS  0x0010
#define SIP_TRACE_METHODS   0x0020


/*
 * Hide some thread dependent stuff.
 */
typedef PyGILState_STATE sip_gilstate_t;
#define SIP_RELEASE_GIL(gs) PyGILState_Release(gs);
#define SIP_BLOCK_THREADS   {PyGILState_STATE sipGIL = PyGILState_Ensure();
#define SIP_UNBLOCK_THREADS PyGILState_Release(sipGIL);}


/*
 * Forward declarations of structures.
 */
struct _sipABISpec;
typedef struct _sipABISpec sipABISpec;

struct _sipBufferDef;
typedef struct _sipBufferDef sipBufferDef;

struct _sipBufferInfoDef;
typedef struct _sipBufferInfoDef sipBufferInfoDef;

struct _sipCFunctionDef;
typedef struct _sipCFunctionDef sipCFunctionDef;

struct _sipClassTypeSpec;
typedef struct _sipClassTypeSpec sipClassTypeSpec;

struct _sipDelayedDtor;
typedef struct _sipDelayedDtor sipDelayedDtor;

struct _sipDateDef;
typedef struct _sipDateDef sipDateDef;

struct _sipEnumTypeSpec;
typedef struct _sipEnumTypeSpec sipEnumTypeSpec;

struct _sipImportedModule;
typedef struct _sipImportedModule sipImportedModule;

struct _sipMethodDef;
typedef struct _sipMethodDef sipMethodDef;

struct _sipModuleSpec;
typedef struct _sipModuleSpec sipModuleSpec;

struct _sipTimeDef;
typedef struct _sipTimeDef sipTimeDef;

struct _sipTypeSpec;
typedef struct _sipTypeSpec sipTypeSpec;


/* The bootstrap API that supports standalone and embedded sip modules. */
typedef const sipABISpec *(*sipBootstrapFunc)(int abi_major);
int sip_api_module_exec(PyObject *mod, const sipModuleSpec *m_spec);


/*
 * The different events a handler can be registered for.
 */
typedef enum
{
    sipEventWrappingInstance,   /* Before wrapping a C/C++ instance. */
    sipEventWrappedInstance,    /* After wrapping a C/C++ instance. */
    sipEventCollectingWrapper,  /* When garbage collecting a wrapper object. */
    sipEventFinalisingType,     /* When finalising a wrapper type. */
    sipEventPySubclassCreated,  /* When a Python subclass of a C++ class has been created. */
    sipEventNrEvents
} sipEventType;

/*
 * The event handlers.
 */
typedef void *(*sipWrappingInstanceEventHandler)(const sipTypeSpec *ts,
        void *sipCpp);
typedef int (*sipWrappedInstanceEventHandler)(const sipTypeSpec *ts,
        void *sipCpp);
typedef int (*sipCollectingWrapperEventHandler)(const sipTypeSpec *ts,
        PyObject *winst);
typedef int (*sipFinalisingTypeEventHandler)(const sipTypeSpec *ts,
        PyObject *dict);
typedef int (*sipPySubclassCreatedEventHandler)(const sipTypeSpec *ts,
        PyTypeObject *wtype);


/*
 * A wrapped type ID.
 */
typedef uint32_t sipTypeID;
typedef uint16_t sipTypeNr;
typedef uint8_t sipModuleNr;


/*
 * Some convenient function pointers.
 */
typedef void *(*sipInitFunc)(PyObject *, PyObject *const *, Py_ssize_t,
        PyObject *, PyObject **, PyObject **, PyObject **);
typedef int (*sipFinalFunc)(PyObject *, void *, PyObject *, PyObject **);
typedef int (*sipTraverseFunc)(void *, visitproc, void *);
typedef int (*sipClearFunc)(void *);
typedef int (*sipGetBufferFuncLimited)(PyObject *, void *, sipBufferDef *);
typedef void (*sipReleaseBufferFuncLimited)(PyObject *, void *);
#if !defined(Py_LIMITED_API)
typedef int (*sipGetBufferFunc)(PyObject *, void *, Py_buffer *, int);
typedef void (*sipReleaseBufferFunc)(PyObject *, void *, Py_buffer *);
#endif
typedef void (*sipDeallocFunc)(PyObject *);
typedef void *(*sipCastFunc)(void *, void *, const sipClassTypeSpec *);
typedef PyObject *(*sipSubClassConvertFunc)(void **, sipTypeID *);
typedef int (*sipConvertToFunc)(PyObject *, PyObject *, void **, int *,
        PyObject *, void **);
typedef PyObject *(*sipConvertFromFunc)(PyObject *, void *, PyObject *);
typedef void (*sipVirtErrorHandlerFunc)(PyObject *, sip_gilstate_t);
typedef int (*sipVirtHandlerFunc)(sip_gilstate_t, sipVirtErrorHandlerFunc,
        PyObject *, PyObject *, ...);
typedef void (*sipAssignFunc)(void *, Py_ssize_t, void *);
typedef void *(*sipArrayFunc)(Py_ssize_t);
typedef void (*sipArrayDeleteFunc)(void *);
typedef void *(*sipCopyFunc)(const void *, Py_ssize_t);
typedef void (*sipReleaseFunc)(void *, int);
typedef void (*sipReleaseUSFunc)(void *, int, void *);
typedef PyObject *(*sipPickleFunc)(void *);
typedef void *(*sipVariableAddrGetterFunc)(void *);
typedef void (*sipWrapperVisitorFunc)(PyObject *, void *);


/*
 * The storage for a pointer and all integer values (as used as enum base
 * types).
 */
// TODO Is the union only for Py enums?
typedef union {
    void *ptr_t;
    bool bool_t;
    char byte_t;
    signed char sbyte_t;
    unsigned char ubyte_t;
    short short_t;
    unsigned short ushort_t;
    int int_t;
    unsigned uint_t;
    long long_t;
    unsigned long ulong_t;
    long long longlong_t;
    unsigned long long ulonglong_t;
} sipTypedValue;


/*
 * The immutable specification of a wrapped named enum member.
 */
typedef struct _sipEnumMemberSpec {
    /* The member name. */
    const char *name;

    /* The member value. */
    sipTypedValue value;

#if defined(SIP_CONFIGURATION_CustomEnums)
    // TODO Is this still needed?
    /* The number of the containing enum, -ve if anonymous. */
    int enum_nr;
#endif
} sipEnumMemberSpec;


/*
 * The immutable specification of a wrapped variable.
 */
#define SIP_WV_RO           INT_MIN     /* The value is read only. */
#define SIP_WV_LITERAL      INT_MIN+1   /* The value is literal. */

typedef void *(*sipVariableAddrGetFunc)(void *);

typedef PyObject *(*sipVariableGetCodeFunc)();
typedef int (*sipVariableSetCodeFunc)(PyObject *);

typedef struct {
    /* The Python name of the variable. */
    const char *name;

    /* The type of the variable's value. */
    sipTypeID type_id;

    /* The key or SIP_WV_*. */
    int key;

    /*
     * The value of the variable.  If it is an enum member then this is the
     * fixed value.  If it is unbound then it is the address of the variable.
     * If the variable is bound then it is the address of a getter.
     */
    sipTypedValue value;

    /* The optional %GetCode wrapper. */
    sipVariableGetCodeFunc get_code;

    /* The optional %SetCode wrapper. */
    sipVariableSetCodeFunc set_code;
} sipVariableSpec;


/*
 * The immutable specification of a type initialiser extender.
 */
// TODO Convert to Spec.  May have a linked list (Def) of Spec objects.
typedef struct _sipInitExtenderDef {
    /* The extender function. */
    sipInitFunc extender;

    /* The class being extended. */
    sipTypeID type_id;

    /* The next extender for this class. */
    // TODO Make this const or remove it.
    struct _sipInitExtenderDef *next;
} sipInitExtenderDef;


/*
 * The immutable specification of a sub-class convertor.
 */
// TODO Convert to Spec.
typedef struct _sipSubClassConvertorDef {
    /* The convertor. */
    sipSubClassConvertFunc convertor;

    /* The base type ID. */
    sipTypeID base_id;
} sipSubClassConvertorDef;


/*
 * The structure populated by %BIGetBufferCode when the limited API is enabled.
 */
// TODO Review a) the need, b) can it be opaque, c) the field prefixes.
struct _sipBufferDef {
    /* The address of the buffer. */
    void *bd_buffer;

    /* The length of the buffer. */
    Py_ssize_t bd_length;

    /* Set if the buffer is read-only. */
    int bd_readonly;
};


/*
 * The structure describing a Python buffer.
 */
// TODO Review a) the need, b) can it be opaque, c) the field prefixes.
struct _sipBufferInfoDef {
    /* This is internal to sip. */
    void *bi_internal;

    /* The address of the buffer. */
    void *bi_buf;

    /* A reference to the object implementing the buffer interface. */
    PyObject *bi_obj;

    /* The length of the buffer in bytes. */
    Py_ssize_t bi_len;

    /* Set if the buffer is read-only. */
    int bi_readonly;

    /* The format of each element of the buffer. */
    char *bi_format;
};


/*
 * The structure describing a Python C function.
 */
// TODO Review a) the need, b) can it be opaque, c) the field prefixes.
struct _sipCFunctionDef {
    /* The C function. */
    PyMethodDef *cf_function;

    /* The optional bound object. */
    PyObject *cf_self;
};


/*
 * The structure describing a Python method.
 */
// TODO Review a) the need, b) can it be opaque, c) the field prefixes.
struct _sipMethodDef {
    /* The function that implements the method. */
    PyObject *pm_function;

    /* The bound object. */
    PyObject *pm_self;
};


/*
 * The structure describing a Python date.
 */
// TODO Review a) the need, b) can it be opaque, c) the field prefixes.
struct _sipDateDef {
    /* The year. */
    int pd_year;

    /* The month (1-12). */
    int pd_month;

    /* The day (1-31). */
    int pd_day;
};


/*
 * The structure describing a Python time.
 */
// TODO Review a) the need, b) can it be opaque, c) the field prefixes.
struct _sipTimeDef {
    /* The hour (0-23). */
    int pt_hour;

    /* The minute (0-59). */
    int pt_minute;

    /* The second (0-59). */
    int pt_second;

    /* The microsecond (0-999999). */
    int pt_microsecond;
};


/*
 * The different error states of handwritten code.
 */
typedef enum {
    sipErrorNone,       /* There is no error. */
    sipErrorFail,       /* The error is a failure. */
    sipErrorContinue    /* It may not apply if a later operation succeeds. */
} sipErrorState;


/*
 * The immutable specification of a Python slot extender.
 */
// TODO Rename to Spec
typedef struct _sipPySlotExtenderDef {
    /* The function. */
    const void *extender;

    /* The slot ID (eg. Py_tp_str). */
    int slot_id;

    /* The class containing the slot. */
    sipTypeID type_id;
} sipPySlotExtenderDef;


/*
 * The immutable specification of a typedef.
 */
typedef struct _sipTypedefSpec {
    /* The typedef name. */
    const char *name;

    /* The typedef value. */
    const char *type_name;
} sipTypedefSpec;


/*
 * The immutable specification of a variable or property.
 */
// TODO This would only be used for properties - still needed?
// TODO Rename to Spec

typedef enum
{
    PropertyVariable,       /* A property. */
    InstanceVariable,       /* An instance variable. */
    ClassVariable           /* A class (i.e. static) variable. */
} sipVariableType;

typedef struct _sipVariableDef {
    /* The type of variable. */
    sipVariableType type;

    /* The name. */
    const char *name;

    /*
     * The getter.  If this is a variable (rather than a property) then the
     * actual type is sipVariableGetterFunc.
     */
    const PyMethodDef *getter;

    /*
     * The setter.  If this is a variable (rather than a property) then the
     * actual type is sipVariableSetterFunc.  It is NULL if the property cannot
     * be set or the variable is const.
     */
    const PyMethodDef *setter;

    /* The property deleter. */
    const PyMethodDef *deleter;

    /* The docstring.  This is only used for properties. */
    const char *docstring;
} sipVariableDef;


/*
 * The immutable specification of the wrapped attributes of either a module or
 * a type.
 */
typedef struct {
    /* The number of static variables. */
    size_t nr_static_variables;

    /* The table of static variables. */
    const sipVariableSpec *const static_variables;

    /* The number of types. */
    sipTypeNr nr_types;

    /*
     * The table of type numbers.  A full type ID isn't required as they refer
     * to local types.
     */
    const sipTypeNr *type_nrs;
} sipAttrsSpec;


/*
 * The immutable specification of a type, either a C++ class (or C struct), a
 * C++ namespace, a mapped type or a named (scoped or unscoped) enum.
 */
// TODO Add a new ParamaterisedType type of definition that will be accessed
// using a module number/type number and will be used to define any type that
// cannot be encapsulated in a sipTypeID because additional parameters are
// required.  The only current use is to implement named capsules but it could
// also be used to implement fixed sized arrays.
struct _sipTypeSpec {
    /* Type flags, see the sipType*() macros. */
    int flags;

    /* The C/C++ name of the type. */
    const char *cpp_name;

    /* Any additional fixed data generated by a plugin. */
    const void *plugin_data;
};


/*
 * The immutable specification of a container (ie. a class, namespace or a
 * mapped type).
 */
typedef struct _sipContainerSpec {
    /*
     * The fully qualified Python name of the type (ie. the tp_name field),
     * NULL if this is a namespace extender (in the context of a class) or
     * doesn't require a namespace (in the context of a mapped type).
     */
    const char *fq_py_name;

    /*
     * The scoping type or the namespace this is extending if it is a namespace
     * extender.
     */
    // TODO This should be a sipTypeNr but it depends on how namespace
    // extenders are implemented (ie. is it a direct reference to an external
    // type or a reference to a local type that then redirects to the external
    // type?  Also do we need to represent a global with a -ve scope nr, so
    // so needs to be an int?
    sipTypeID scope_id;

    /* The table of instance variables. */
    const sipVariableSpec *const instance_variables;

    /* The unbound wrapped attributes. */
    sipAttrsSpec attributes;

    /* The table of Python slots. */
    const PyType_Slot *py_slots;

    /* The table of methods. */
    const PyMethodDef *methods;
} sipContainerSpec;


/*
 * The immutable specification of a C++ class (or C struct) or a C++ namespace.
 */
struct _sipClassTypeSpec {
    /* The base type information. */
    sipTypeSpec base;

    /* The container information. */
    sipContainerSpec container;

    /* The docstring. */
    const char *docstring;

    /*
     * The meta-type name, NULL to use the meta-type of the first super-type
     * (normally sipWrapperType).
     */
    const char *metatype;

    /* The super-type name, NULL to use sipWrapper. */
    const char *supertype;

    /* The super-types. */
    const sipTypeID *supers;

    /* The initialisation function. */
    sipInitFunc init;

    /* The traverse function. */
    sipTraverseFunc traverse;

    /* The clear function. */
    sipClearFunc clear;

    /* The get buffer function. */
#if defined(Py_LIMITED_API)
    sipGetBufferFuncLimited getbuffer;
#else
    sipGetBufferFunc getbuffer;
#endif

    /* The release buffer function. */
#if defined(Py_LIMITED_API)
    sipReleaseBufferFuncLimited releasebuffer;
#else
    sipReleaseBufferFunc releasebuffer;
#endif

    /* The optional deallocation function. */
    sipDeallocFunc dealloc;

    /* The optional assignment function. */
    sipAssignFunc assign;

    /* The optional array allocation function. */
    sipArrayFunc array;

    /* The optional copy function. */
    sipCopyFunc copy;

    /* The release function, 0 if a C struct. */
    sipReleaseFunc release;

    /* The cast function, 0 if a C struct. */
    sipCastFunc cast;

    /* The optional convert to function. */
    sipConvertToFunc cto;

    /* The optional convert from function. */
    sipConvertFromFunc cfrom;

    /* The next namespace extender. */
    // TODO Add const or reimplement.
    struct _sipClassTypeSpec *nsextender;

    /* The pickle function. */
    sipPickleFunc pickle;

    /* The finalisation function. */
    sipFinalFunc final;

    /* The optional array delete function. */
    sipArrayDeleteFunc array_delete;

    /* The sizeof the class. */
    size_t sizeof_class;
};


/*
 * The immutable specification of a mapped type.
 */
typedef struct _sipMappedTypeSpec {
    /* The base type information. */
    sipTypeSpec base;

    /* The container information. */
    sipContainerSpec container;

    /* The optional assignment function. */
    sipAssignFunc assign;

    /* The optional array allocation function. */
    sipArrayFunc array;

    /* The optional copy function. */
    sipCopyFunc copy;

    /* The optional release function. */
    sipReleaseUSFunc release;

    /* The optional convert to function. */
    sipConvertToFunc cto;

    /* The optional convert from function. */
    sipConvertFromFunc cfrom;
} sipMappedTypeSpec;


/*
 * The immutable specification of a named enum.
 */
struct _sipEnumTypeSpec {
    /* The base type information. */
    sipTypeSpec base;

    /* The C/C++ base type. */
    sipTypeID cpp_base_type;

    /* The fully qualified Python name of the enum. */
    const char *fq_py_name;

    /* The table of members. */
    const sipEnumMemberSpec *members;

#if defined(SIP_CONFIGURATION_PyEnums)
    /* The Python base type. */
    int py_base_type;
#endif

    /* The table of Python slots. */
    const PyType_Slot *py_slots;

    /* The type number of the scope or -1 if at the module level. */
    // TODO May need to be a type ID if the scope is a namespace extender.
    int scope_nr;
};


/*
 * The immutable specification of an external type.
 */
// TODO Rename to Spec
typedef struct _sipExternalTypeDef {
    /* The index into the type table.  -1 indicates the end of the table. */
    int type_nr;

    /* The Python name of the type. */
    const char *py_name;
} sipExternalTypeDef;


/*
 * Defines an entry in the module specific list of delayed dtor calls.
 */
// TODO This can be opaque in this file.
struct _sipDelayedDtor {
    /* The C/C++ instance. */
    void *ptr;

    /* The fully qualified Python class name. */
    const char *name;

    /* Non-zero if ptr is a derived class instance. */
    int isderived;

    /* Next in the list. */
    struct _sipDelayedDtor *next;
};


/*
 * The immutable specification of a virtual error handler.
 */
// TODO Rename to Spec
typedef struct _sipVirtErrorHandlerDef {
    /* The name of the handler. */
    const char *name;

    /* The handler function. */
    sipVirtErrorHandlerFunc handler;
} sipVirtErrorHandlerDef;


/*
 * The immutable specification of a wrapped module.
 */
struct _sipModuleSpec {
    /* The SIP ABI major version number. */
    unsigned abi_major;

    /* The SIP ABI minor version number. */
    unsigned abi_minor;

    /* The required sip module configuration. */
    unsigned sip_configuration;

    /* The number of imported modules. */
    int nr_imports;

    /* The names of the imported modules. */
    const char *const *imports;

    /* The number of wrapped type specifications. */
    // TODO This should be sipTypeNr rather than int.
    int nr_type_specs;

    /* The table of wrapped type specifications. */
    const sipTypeSpec *const *type_specs;

    /* The table of external types. */
    // TODO This probably goes.
    const sipExternalTypeDef *const external;

    /* The number of typedefs. */
    int nr_typedefs;

    /* The table of typedefs. */
    const sipTypedefSpec *const typedefs;

    /* The table of virtual error handlers. */
    const sipVirtErrorHandlerDef *const virt_error_handlers;

    /* The sub-class convertors. */
    const sipSubClassConvertorDef *const convertors;

    /* The wrapped attributes. */
    sipAttrsSpec attributes;

    /* The license. */
    const struct _sipLicenseDef *license;

    /* The table of exception types. */
    // TODO Move to the module state.
    PyObject **exceptions;

    /* The table of Python slot extenders. */
    const sipPySlotExtenderDef *const slot_extend;

    /* The table of initialiser extenders. */
    const sipInitExtenderDef *const init_extend;

    /* The delayed dtor handler. */
    const void (*delayeddtors)(const struct _sipDelayedDtor *);

    /* The exception handler. */
    sipExceptionHandler exception_handler;
};


/*
 * The immutable specification of a license to be added to a dictionary.
 */
// TODO Rename to Spec
typedef struct _sipLicenseDef {
    /* The type of license. */
    const char *type;

    /* The licensee. */
    const char *licensee;

    /* The timestamp. */
    const char *timestamp;

    /* The signature. */
    const char *signature;
} sipLicenseDef;


/*
 * The immutable ABI exported by the SIP module, ie. pointers to all the data
 * and functions that can be used by generated code.  Note that the offset of
 * each field doesn't change if the module configuration options do change.
 */
struct _sipABISpec {
    size_t module_state_size;   /* The sizeof the wrapped module state */

    /*
     * The following are part of the public ABI.
     */
    void (*api_bad_catcher_result)(PyObject *method);
    void (*api_bad_length_for_slice)(Py_ssize_t seqlen, Py_ssize_t slicelen);
    PyObject *(*api_build_result)(PyObject *mod, int *is_err_p,
            const char *fmt, ...);
    PyObject *(*api_call_method)(PyObject *mod, int *is_err_p,
            PyObject *method, const char *fmt, ...);
    void (*api_call_procedure_method)(PyObject *mod, sip_gilstate_t gil_state,
            sipVirtErrorHandlerFunc error_handler, PyObject *py_self,
            PyObject *method, const char *fmt, ...);
    Py_ssize_t (*api_convert_from_sequence_index)(Py_ssize_t idx,
            Py_ssize_t len);
    int (*api_can_convert_to_type)(PyObject *mod, PyObject *pyObj,
            sipTypeID type_id, int flags);
    void *(*api_convert_to_type)(PyObject *mod, PyObject *pyObj,
            sipTypeID type_id, PyObject *transferObj, int flags, int *statep,
            int *iserrp);
    void *(*api_convert_to_type_us)(PyObject *mod, PyObject *pyObj,
            sipTypeID type_id, PyObject *transferObj, int flags, int *statep,
            void **user_statep, int *iserrp);
    void *(*api_force_convert_to_type)(PyObject *mod, PyObject *pyObj,
            sipTypeID type_id, PyObject *transferObj, int flags, int *statep,
            int *iserrp);
    void *(*api_force_convert_to_type_us)(PyObject *mod, PyObject *pyObj,
            sipTypeID type_id, PyObject *transferObj, int flags, int *statep,
            void **user_statep, int *iserrp);
    void (*api_release_type)(PyObject *mod, void *cpp, sipTypeID type_id,
            int state);
    void (*api_release_type_us)(PyObject *mod, void *cpp, sipTypeID type_id,
            int state, void *user_state);
