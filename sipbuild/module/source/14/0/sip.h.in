/*
 * These are flags that can be passed to sipCanConvertToType(),
 * sipConvertToType() and sipForceConvertToType().
 */
#define SIP_NOT_NONE        0x01    /* Disallow None. */
#define SIP_NO_CONVERTORS   0x02    /* Disable any type convertors. */


/*
 * These are flags that can be passed to sipConvertToArray().
 */
#define SIP_READ_ONLY       0x01    /* The array is read-only. */
#define SIP_OWNS_MEMORY     0x02    /* The array owns its memory. */


/*
 * These are the state flags returned by %ConvertToTypeCode.  Note that the
 * values share the same "flagspace" as the contents of flags.
 */
#define SIP_TEMPORARY       0x0001  /* A temporary instance. */
#define SIP_DERIVED_CLASS   0x0002  /* The instance is derived. */
#define SIP_USER            0x0004  /* For use by the user. */
#define SIP_RESERVED        0x0008  /* Reserved for future use by this ABI version. */


/*
 * Useful macros (exposed by the ABI but not part of the public API).
 */

/*
 * A type ID is a 32 bit value.  The value (unless it is an absolute type ID)
 * is interpreted in the context of the module from which it is used.  For
 * example a class A.K (ie. class K defined in module A) with have different
 * type IDs when referenced from module A and module B.  However the symbolic
 * name of these different type IDs will be the same.  Absolute type IDs are
 * created dynamically by sipFindTypeID() and their values do not need a module
 * context to be interpreted.
 *
 * The most significant 3 bits of the value specify the general type, either a
 * type that has an immutable type definition (eg. a class) or a POD type.
 * type.
 *
 * The next 2 bits are currently unused.
 *
 * The next 3 bits are flags common to all type IDs.
 *
 * If the type is a POD type then the remaining 24 bits specify the particular
 * type (although only 10 bits are currently used).
 *
 * For other types the next 8 bits specify the number (in the context of the
 * module from which the value is used) of the module that contains the
 * immutable type definition.  The final 16 bits specify the number of the
 * type definition (in the context of the module that contains it).
 *
 * The values of certain fields are designed so that 0 is an invalid type ID.
 */
// TODO The above is broken for imported types as it uses an index into the
// imported module's data (which may change from version to version).  Instead
// it should be done as in older ABIs where the imported type is only referred
// to by name (ie. an index into a list of imported types).

/* The general type part of a type ID. */
#define SIP_TYPE_ID_TYPE_MASK           0xe0000000
#define SIP_TYPE_ID_TYPE_POD            0x00000000      /* This must be 0. */
#define SIP_TYPE_ID_TYPE_CLASS          0x20000000
#define SIP_TYPE_ID_TYPE_MAPPED         0x40000000
#define SIP_TYPE_ID_TYPE_ENUM           0x60000000

/* The flags part of a type ID. */
#define SIP_TYPE_ID_SENTINEL            0x01000000
#define SIP_TYPE_ID_ABSOLUTE            0x02000000
#define SIP_TYPE_ID_EXTERNAL            0x04000000

/* The unused parts of a type ID. */
#define SIP_TYPE_ID_UNUSED_1            0x08000000
#define SIP_TYPE_ID_UNUSED_2            0x01000000

/* The number of the current module. */
#define SIP_TYPE_ID_CURRENT_MODULE      0x00ff0000


/* The invalid type ID.  It must be 0. */
#define sipTypeID_Invalid       0

/* The type IDs of POD types.  These must start from 1. */
#define sipTypeID_byte          0x000001
#define sipTypeID_sbyte         0x000002
#define sipTypeID_ubyte         0x000003
#define sipTypeID_short         0x000004
#define sipTypeID_ushort        0x000005
#define sipTypeID_int           0x000006
#define sipTypeID_uint          0x000007
#define sipTypeID_long          0x000008
#define sipTypeID_ulong         0x000009
#define sipTypeID_longlong      0x00000a
#define sipTypeID_ulonglong     0x00000b
#define sipTypeID_Py_hash_t     0x00000c
#define sipTypeID_Py_ssize_t    0x00000d
#define sipTypeID_size_t        0x00000e
#define sipTypeID_float         0x00000f
#define sipTypeID_double        0x000010
#define sipTypeID_char          0x000011
#define sipTypeID_char_ascii    0x000111
#define sipTypeID_char_latin1   0x000211
#define sipTypeID_char_utf8     0x000311
#define sipTypeID_schar         0x000012
#define sipTypeID_uchar         0x000013
#define sipTypeID_wchar         0x000014
#define sipTypeID_str           0x000015
#define sipTypeID_str_ascii     0x000115
#define sipTypeID_str_latin1    0x000215
#define sipTypeID_str_utf8      0x000315
#define sipTypeID_sstr          0x000016
#define sipTypeID_ustr          0x000017
#define sipTypeID_wstr          0x000018
#define sipTypeID_bool          0x000019
#define sipTypeID_voidptr       0x00001a
#define sipTypeID_voidptr_const 0x00001b
#define sipTypeID_pyobject      0x00001c
#define sipTypeID_pytuple       0x00001d
#define sipTypeID_pylist        0x00001e
#define sipTypeID_pydict        0x00001f
#define sipTypeID_pycallable    0x000020
#define sipTypeID_pyslice       0x000021
#define sipTypeID_pytype        0x000022
#define sipTypeID_pybuffer      0x000023
#define sipTypeID_pycapsule     0x000024


#define SIP_TYPE_TYPE_MASK  0x0007  /* The type type mask. */
#define SIP_TYPE_CLASS      0x0000  /* If the type is a C++ class. */
#define SIP_TYPE_NAMESPACE  0x0001  /* If the type is a C++ namespace. */
#define SIP_TYPE_MAPPED     0x0002  /* If the type is a mapped type. */
#define SIP_TYPE_ENUM       0x0003  /* If the type is an enum. */
#if defined(SIP_CONFIGURATION_CustomEnums)
#define SIP_TYPE_SCOPED_ENUM    0x0004  /* If the type is a scoped enum. */
#endif
#define SIP_TYPE_ABSTRACT   0x0008  /* If the type is abstract. */
#define SIP_TYPE_SCC        0x0010  /* If the type is subject to sub-class convertors. */
#define SIP_TYPE_ALLOW_NONE 0x0020  /* If the type can handle None. */
#define SIP_TYPE_NONLAZY    0x0040  /* If the type has a non-lazy method. */
#define SIP_TYPE_SUPER_INIT 0x0080  /* If the instance's super init should be called. */
#define SIP_TYPE_LIMITED_API    0x0100  /* Use the limited API.  If this is more generally required it may need to be moved to the module definition. */
#define SIP_TYPE_USER_STATE 0x0200  /* If the convertors need user state. */


#if defined(SIP_CONFIGURATION_PyEnums)
/* The Python base types of enums. */
#define SIP_ENUM_ENUM       0       /* The base type is Enum. */
#define SIP_ENUM_FLAG       1       /* The base type is Flag. */
#define SIP_ENUM_INT_ENUM   2       /* The base type is IntEnum. */
#define SIP_ENUM_INT_FLAG   3       /* The base type is IntFlag. */
#define SIP_ENUM_UINT_ENUM  4       /* The base type is IntEnum with unsigned members. */
#endif


/*
 * The following are part of the public API.
 */
// TODO Review if the type specs are part of the public API.
#define sipTypeIsClass(ts)  (((ts)->flags & SIP_TYPE_TYPE_MASK) == SIP_TYPE_CLASS)
#define sipTypeIsNamespace(ts)  (((ts)->flags & SIP_TYPE_TYPE_MASK) == SIP_TYPE_NAMESPACE)
#define sipTypeIsMapped(ts) (((ts)->flags & SIP_TYPE_TYPE_MASK) == SIP_TYPE_MAPPED)
#define sipTypeIsEnum(ts)   (((ts)->flags & SIP_TYPE_TYPE_MASK) == SIP_TYPE_ENUM)
#if defined(SIP_CONFIGURATION_CustomEnums)
#define sipTypeIsScopedEnum(ts) (((ts)->flags & SIP_TYPE_TYPE_MASK) == SIP_TYPE_SCOPED_ENUM)
#endif
#define sipTypePluginData(ts)   ((ts)->plugin_data)


/*
 * The following are not part of the public API.
 */
#define sipTypeNeedsUserState(ts)   ((ts)->flags & SIP_TYPE_USER_STATE)
#define sipTypeIsAbstract(ts)       ((ts)->flags & SIP_TYPE_ABSTRACT)
#define sipTypeHasSCC(ts)           ((ts)->flags & SIP_TYPE_SCC)
#define sipTypeAllowNone(ts)        ((ts)->flags & SIP_TYPE_ALLOW_NONE)
#define sipTypeHasNonlazyMethod(ts) ((ts)->flags & SIP_TYPE_NONLAZY)
#define sipTypeCallSuperInit(ts)    ((ts)->flags & SIP_TYPE_SUPER_INIT)
#define sipTypeUseLimitedAPI(ts)    ((ts)->flags & SIP_TYPE_LIMITED_API)


/*
 * The following are PyQt-specific extensions.  These may be removed in SIP v7.
 * Note that, at the moment, the PyQt5 and PyQt6 extensions are identical.
 */

/*
 * The description of a Qt signal for PyQt5.
 */
typedef int (*pyqt5EmitFunc)(void *, PyObject *);

typedef struct _pyqt5QtSignal {
    /* The normalised C++ name and signature of the signal. */
    const char *signature;

    /* The optional docstring. */
    const char *docstring;

    /*
     * If the signal is an overload of regular methods then this points to the
     * code that implements those methods.
     */
    PyMethodDef *non_signals;

    /*
     * If the signal has optional arguments then this function will implement
     * emit() for the signal.
     */
    pyqt5EmitFunc emitter;
} pyqt5QtSignal;


/*
 * This is the PyQt5-specific extension to the generated class type structure.
 */
typedef struct _pyqt5ClassPluginDef {
    /* A pointer to the QObject sub-class's staticMetaObject class variable. */
    const void *static_metaobject;

    /*
     * A set of flags.  At the moment only bit 0 is used to say if the type is
     * derived from QFlags.
     */
    unsigned flags;

    /*
     * The table of signals emitted by the type.  These are grouped by signal
     * name.
     */
    const pyqt5QtSignal *qt_signals;

    /* The name of the interface that the class defines. */
    const char *qt_interface;
} pyqt5ClassPluginDef;


/*
 * The description of a Qt signal for PyQt6.
 */
typedef int (*pyqt6EmitFunc)(void *, PyObject *);

typedef struct _pyqt6QtSignal {
    /* The normalised C++ name and signature of the signal. */
    const char *signature;

    /* The optional docstring. */
    const char *docstring;

    /*
     * If the signal is an overload of regular methods then this points to the
     * code that implements those methods.
     */
    PyMethodDef *non_signals;

    /*
     * If the signal has optional arguments then this function will implement
     * emit() for the signal.
     */
    pyqt6EmitFunc emitter;
} pyqt6QtSignal;


/*
 * This is the PyQt6-specific extension to the generated class type structure.
 */
typedef struct _pyqt6ClassPluginDef {
    /* A pointer to the QObject sub-class's staticMetaObject class variable. */
    const void *static_metaobject;

    /*
     * The table of signals emitted by the type.  These are grouped by signal
     * name.
     */
    const pyqt6QtSignal *qt_signals;

    /* The name of the interface that the class defines. */
    const char *qt_interface;
} pyqt6ClassPluginDef;


/*
 * This is the PyQt6-specific extension to the generated mapped type structure.
 */
typedef struct _pyqt6MappedTypePluginDef {
    /*
     * A set of flags.  At the moment only bit 0 is used to say if the type is
     * mapped to/from QFlags.
     */
    unsigned flags;
} pyqt6MappedTypePluginDef;


#ifdef __cplusplus
}
#endif


#endif
